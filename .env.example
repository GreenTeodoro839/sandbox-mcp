# Copy to .env and edit. The systemd unit loads this file.

# --- REQUIRED ---
# Bearer token Miclaw must send. Generate e.g.: openssl rand -hex 32
SMCP_TOKEN=change-me-to-a-long-random-string
# Public address as reached through your frp tunnel (used to build file URLs).
SMCP_PUBLIC_BASE_URL=https://sandbox.example.com

# --- listen address (frpc forwards to this) ---
SMCP_HOST=127.0.0.1
SMCP_PORT=8000

# --- optional: separate key for signing file URLs (defaults to SMCP_TOKEN) ---
# SMCP_SIGNING_KEY=another-long-random-string

# --- storage (host paths) ---
SMCP_DATA_DIR=/var/lib/sandbox-mcp/data
SMCP_STATE_DB=/var/lib/sandbox-mcp/state.db

# --- sandbox containers ---
SMCP_BASE_IMAGE=sandbox-mcp-base:latest
SMCP_SANDBOX_NETWORK=bridge        # set to "none" to cut off sandbox networking
SMCP_MEM_LIMIT=2g
SMCP_CPUS=2
SMCP_PIDS_LIMIT=512
SMCP_MAX_SANDBOXES=20

# --- lifecycle / timeouts (seconds) ---
SMCP_IDLE_STOP_SECONDS=7200        # stop a sandbox after 2h idle
SMCP_IDLE_REMOVE_SECONDS=604800    # remove a sandbox after 7d idle
SMCP_GC_INTERVAL_SECONDS=300
SMCP_EXEC_TIMEOUT=60               # default exec timeout
SMCP_JOB_TIMEOUT=3600              # default background-job timeout
SMCP_JOB_LOG_RETENTION=86400       # keep background-job logs this long, then GC
SMCP_URL_TTL=3600                  # file URL validity
SMCP_READ_TEXT_MAX_BYTES=200000    # inline read_text size guard
